{
  "name": "welltegra.network",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "dev:serve": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch & npx serve -l 5173 .",
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify"
  },
  "devDependencies": {
    "serve": "^14.2.3",
    "tailwindcss": "^3.4.10"
  }
}
