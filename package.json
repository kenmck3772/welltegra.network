# package.json
cat > package.json <<'EOF'
{
  "name": "welltegra",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.10"
  }
}
EOF
# tailwind.config.js
cat > tailwind.config.js <<'EOF'
/** @type {import('tailwindcss').Config} */
module.exports = {
  content: [
    "./index.html",
    "./**/*.{html,js,ts}"
  ],
  theme: { extend: {} },
  plugins: [],
};
EOF
# src/input.css
mkdir -p src assets
cat > src/input.css <<'EOF'
@tailwind base;
@tailwind components;
@tailwind utilities;
:root { --wt-scale: 1; }
html { font-size: calc(16px * var(--wt-scale)); }
*:focus-visible { outline: 3px solid #38bdf8; outline-offset: 2px; }
.theme-dark .light-card { background-color:#1f2937; border:1px solid #334155; }
.theme-light .light-card { background:#ffffff; }
.status-available,.status-active-underperforming,.status-active-lowinjectivity,.status-approved,.status-mustered,.status-passed,.status-active-restoredproduction,.status-pa-successful { background:#dcfce7; color:#166534; border-radius:9999px; padding:2px 8px; }
.status-maintenance,.status-pending,.status-intransit,.status-standby { background:#fef9c3; color:#854d0e; border-radius:9999px; padding:2px 8px; }
.status-unavailable,.status-onjob,.status-expired,.status-unaccounted,.status-failed,.status-drilling-criticalsection,.status-shut-in,.status-shut-in-wellintegrityissues,.status-pacandidate { background:#fee2e2; color:#991b1b; border-radius:9999px; padding:2px 8px; }
.status-onboard { background:#cffafe; color:#0e7490; border-radius:9999px; padding:2px 8px; }
.risk-low{background:#dcfce7;color:#166534;border-radius:9999px;padding:2px 8px}
.risk-medium{background:#fef9c3;color:#854d0e;border-radius:9999px;padding:2px 8px}
.risk-high{background:#fee2e2;color:#991b1b;border-radius:9999px;padding:2px 8px}
.planner-card{transition:transform .2s}
.planner-card:hover{transform:translateY(-4px)}
EOF
git add -A && git commit -m "tooling: local tailwind + component css"
