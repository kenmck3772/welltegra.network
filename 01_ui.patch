 </script>
+<!-- Floating “A+” zoom control -->
+<button id="zoom-btn" aria-label="Increase text size"
+  class="fixed bottom-4 right-4 z-[60] rounded-full px-4 py-3 shadow-lg bg-blue-600 text-white font-bold hover:bg-blue-500 focus:outline-none">
+  A+
+  <span class="sr-only">Increase text size</span>
+</button>
+<script>
+  (function () {
+    const btn = document.getElementById('zoom-btn');
+    if (!btn) return;
+    const apply = (n) => {
+      const clamped = Math.max(1, Math.min(n, 1.6)); // 100%..160%
+      document.documentElement.style.setProperty('--wt-scale', clamped);
+      localStorage.setItem('wt-scale', String(clamped));
+    };
+    const saved = parseFloat(localStorage.getItem('wt-scale'));
+    if (!isNaN(saved)) apply(saved);
+    btn.addEventListener('click', () => {
+      const current = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--wt-scale')) || 1;
+      const next = current >= 1.6 ? 1 : (current + 0.1);
+      apply(parseFloat(next.toFixed(2)));
+    });
+  })();
+</script>
 </body>
